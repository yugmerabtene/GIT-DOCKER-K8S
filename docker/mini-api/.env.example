# =============================================================================
# .env.example — Variables d'environnement pour le mini-projet
# =============================================================================
#
# OBJECTIF : Definir les variables d'environnement utilisees par Docker Compose
# et l'application FastAPI.
#
# USAGE :
#   1. Copier ce fichier vers .env : cp .env.example .env
#   2. Modifier les valeurs selon votre environnement
#   3. Lancer : docker compose --env-file .env up -d
#
# SECURITE :
#   - Ne jamais committer le fichier .env dans Git
#   - En production, utiliser des secrets Docker/K8s
#   - Changer JWT_SECRET par une valeur aleatoire forte
#
# VERIFICATION :
#   docker compose config  # Doit afficher la configuration resolue
# =============================================================================

# --- Application (JWT) ---
# Secret pour signer les tokens JWT (CHANGER EN PRODUCTION !)
JWT_SECRET=change-me
# Duree de validite des tokens en minutes
JWT_EXPIRE_MIN=60

# --- PostgreSQL ---
# Identifiants de la base de donnees
DB_USER=app
DB_PASSWORD=app
DB_NAME=app_db
# Nom du service Docker Compose pour la base de donnees
DB_HOST=db
